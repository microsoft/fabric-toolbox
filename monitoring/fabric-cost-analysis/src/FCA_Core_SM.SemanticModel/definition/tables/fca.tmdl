	/// Counts the distinct number of regions in the RegionName column of the FCA table
	measure #Regions =
			
			VAR RegionsFromFCA =
			    SUMMARIZE ( fca, 'resources'[RegionId])
			VAR Result =
			    SUMX ( RegionsFromFCA, 1 )     -- optimization for COUNTROWS
			RETURN
			    Result
		formatString: 0
		displayFolder: measures
