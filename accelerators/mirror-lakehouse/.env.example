# Azure AD Application Registration
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here
TENANT_ID=your-tenant-id-here

# Default Configuration (can be overridden in UI)
SOURCE_WORKSPACE_NAME=your-source-workspace
SOURCE_LAKEHOUSE_NAME=your-source-lakehouse
DESTINATION_WORKSPACE_NAME=your-destination-workspace
DESTINATION_LAKEHOUSE_NAME=your-destination-lakehouse

# API Configuration
PORT=3001
CLIENT_PORT=3000
NODE_ENV=development

# Microsoft Fabric API
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1

# Optional SQL analytics endpoint fallback for schema-enabled lakehouses
# Used when Fabric table APIs don't expose table metadata for a lakehouse.
# Example server: yourworkspace.datawarehouse.fabric.microsoft.com
FABRIC_SQL_ENDPOINT_SERVER=
# Default database/catalog name for fallback queries (optional if using map)
FABRIC_SQL_ENDPOINT_DATABASE=
# Optional SQL auth override (if omitted, Entra client credentials are used)
FABRIC_SQL_ENDPOINT_USER=
FABRIC_SQL_ENDPOINT_PASSWORD=
# Optional JSON maps to target specific workspace/lakehouse IDs
# FABRIC_SQL_ENDPOINT_SERVER_MAP={"<workspaceId>":"<server-hostname>"}
# FABRIC_SQL_ENDPOINT_DATABASE_MAP={"<lakehouseId>":"<databaseName>","<workspaceId>/<lakehouseId>":"<databaseName>"}

# Optional integration test toggles for programmable objects
# TEST_APPLY_PROGRAMMABLE_OBJECTS=false
# TEST_PROGRAMMABLE_OBJECT_LIMIT=3

# Authentication
REDIRECT_URI=http://localhost:3000
AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here